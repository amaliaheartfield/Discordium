---
import "../styles/global.css";
const { title = "Discordium Report" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Discordium.org Review: Doxxing, Harassment, GDPR Violations, Discord Server Scam Report</title>
    
    <meta name="description" content="Discordium.org investigation: reports of doxxing, harassment, GDPR violations, fake reviews, and Discord ToS abuse. Read before joining Discord servers, bots, FiveM or Minecraft listings." />
    
    <link rel="canonical" href="https://discordium-org.github.io/Discordium/" />
    
    <!-- Keywords (still useful for some engines) -->
    <meta name="keywords" content="
    Discordium, Discordium.org review, Discordium scam, Nassvoll, Aljoscha Klemcke,
    Discord server advertising, Discord server promotion, Discord bots, Discord bot list,
    best Discord servers, Discord server list, Discord emotes, Discord stickers,
    FiveM servers list, Minecraft servers list, Discord advertising scam,
    GDPR violation Discord, Discord doxxing, Discord harassment, Discord predators
    " />
    
    <!-- Open Graph -->
    <meta property="og:title" content="Discordium Investigation: Doxxing, GDPR Violations, Harassment" />
    <meta property="og:description" content="Evidence-based report on Discordium.org covering doxxing, harassment, fake reviews, and Discord ToS violations." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://discordium-org.github.io/Discordium/" />
    <meta property="og:image" content="https://discordium-org.github.io/Discordium/images/embed.png" />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Discordium.org Investigation" />
    <meta name="twitter:description" content="Doxxing, harassment, GDPR violations and misconduct tied to Discordium." />
    <meta name="twitter:image" content="https://discordium-org.github.io/Discordium/images/embed.png" />
    <meta name="robots" content="index, follow" />
    <meta name="google-site-verification" content="MCcsk0Z5NZc8PyW5MiS9oJJAtY3Kd0SY02vEIXxxYJk" />
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Report",
      "headline": "Discordium.org Investigation: Harassment, Doxxing, GDPR Violations",
      "description": "Independent report documenting allegations of harassment, doxxing, GDPR violations and misconduct related to Discordium.org.",
      "author": {
        "@type": "Organization",
        "name": "Independent Report"
      },
      "publisher": {
        "@type": "Organization",
        "name": "Independent Report"
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "https://discordium-org.github.io/Discordium/"
      },
      "about": [
        "Discordium",
        "Discord servers",
        "Discord bots",
        "FiveM servers",
        "Minecraft servers",
        "GDPR violations",
        "online harassment"
      ]
    }
    </script>
  </head>
  <body style="font-family: sans-serif; background:#0b0f17; color:white; padding:40px;">
    <main>
      <slot />
    </main>
  </body>
</html>
