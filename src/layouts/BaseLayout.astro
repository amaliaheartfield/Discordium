---
const { title = "Discordium Report" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="Discordium investigation, reports, evidence, GDPR violations, Discord ToS issues" />
  </head>
  <body style="font-family: sans-serif; background:#0b0f17; color:white; padding:40px;">
    <main>
      <slot />
    </main>
  </body>
</html>
